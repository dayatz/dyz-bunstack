{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["bun"],
    "paths": {
      "#/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
