{
  "name": "@dyz-bunstack-app/server",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "portless api.dyz-bunstack bun --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun dist/index.js",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:push": "bunx drizzle-kit push",
    "db:studio": "bunx drizzle-kit studio",
    "db:seed": "bun run src/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1006.0",
    "@aws-sdk/s3-request-presigner": "^3.1006.0",
    "@elysiajs/cors": "^1.4.1",
    "better-auth": "^1.5.4",
    "consola": "^3.4.2",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.2.25",
    "postgres": "^3.4.8"
  },
  "devDependencies": {
    "@types/bun": "^1.2.5",
    "drizzle-kit": "^0.31.9",
    "typescript": "^5.7.2"
  }
}
